# HaloPSA MCP — Environment Variables

# Required
HALOPSA_URL=https://your-instance.halopsa.com  # Tenant auto-extracted from subdomain
HALOPSA_CLIENT_ID=your-auth-code-client-id

# --- Auth Code + PKCE mode (recommended, per-user) ---
# Register a new Application in HaloPSA: Config → Integrations → HaloPSA API
# Set Authentication Method = "Authorization Code", add your redirect URI.
# No client secret is needed for PKCE.
HALOPSA_REDIRECT_URI=https://your-domain.com/callback
HALOPSA_TOKEN_STORE=/app/data/tokens.json

# --- Client credentials fallback mode (not recommended) ---
# Set HALOPSA_CLIENT_SECRET for service account authentication.
# HALOPSA_CLIENT_SECRET=your-client-secret

# Auth server port (serves /login, /callback, /status, /health)
HTTP_PORT=3000
MCP_PORT=8000
