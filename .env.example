# HaloPSA MCP — Environment Variables
# Copy to .env and fill in values. .env is gitignored.

# === Required ===
HALOPSA_URL=https://your-instance.halopsa.com
HALOPSA_CLIENT_ID=your-auth-code-client-id

# === OAuth (Authorization Code + PKCE, recommended) ===
# Register a Native Application in HaloPSA: Config → Integrations → HaloPSA API.
# Set Authentication Method = "Authorisation Code (Native Application)".
HALOPSA_REDIRECT_URI=http://localhost:3000/callback

# === Client credentials fallback (only if your HaloPSA tenant requires it) ===
# HALOPSA_CLIENT_SECRET=your-client-secret

# === HTTP server ===
HTTP_PORT=3000
# External base URL used for OAuth callbacks and WWW-Authenticate.
# Local dev: http://localhost:3000. Docker: same. AKS: https://halopsa-mcp.example.com.
AUTH_BASE_URL=http://localhost:3000

# Public base URL used for login links (users click this).
# Defaults to AUTH_BASE_URL. Set when externally reachable URL differs (rare).
# HALOPSA_PUBLIC_URL=https://halopsa-mcp.example.com

# === Token + key storage ===
# Backend: file (default, single-instance) or redis (multi-replica Kubernetes).
# HALOPSA_TOKEN_STORE_BACKEND=file
# HALOPSA_REDIS_CONNECTION=localhost:6379,password=...,ssl=true

# Local dev (stdio): ./data/tokens.json. Container: /app/data/tokens.json.
HALOPSA_TOKEN_STORE=./data/tokens.json
# DataProtection keys directory (encrypts tokens.json + clients.json at rest).
HALOPSA_DPKEY_DIR=./data/dp-keys

# === Security knobs (HTTP mode) ===
# When set, /register (DCR) requires Authorization: Bearer <this token>.
# Required in any internet-exposed deployment. Leave blank for local dev only.
# MCP_DCR_INITIAL_ACCESS_TOKEN=

# Set to "1" to expose detailed health JSON on /ready (for trusted Prometheus
# scrapers inside the cluster). Default is minimal {status} only.
# MCP_READY_VERBOSE=0

# === Logging ===
# json (default) for containers, text for local dev readability.
LOG_FORMAT=json
